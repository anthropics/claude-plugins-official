{
  "description": "Security reminder hook that warns about potential security issues when editing files",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '\"$(command -v python3 || command -v python)\" \"${CLAUDE_PLUGIN_ROOT}/hooks/security_reminder_hook.py\"'"
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      }
    ]
  }
}
