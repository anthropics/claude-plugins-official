{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Skill",
            "Bash(git status)",
            "Bash(git diff*)",
            "Bash(git log*)",
            "Bash(git add*)",
            "Bash(git commit*)",
            "Bash(git push*)",
            "Bash(git fetch*)",
            "Bash(git pull*)",
            "Bash(npm run*)",
            "Bash(node *)"
        ],
        "deny": [
            "Read(**/.env)",
            "Read(**/.env.*)",
            "Read(**/secrets/**)",
            "Read(**/*.pem)",
            "Read(**/*.key)",
            "Write(**/.env)",
            "Write(**/.env.*)",
            "Write(**/secrets/**)",
            "Bash(curl * | bash)",
            "Bash(wget * | bash)",
            "Bash(rm -rf /)",
            "Bash(rm -rf ~*)"
        ],
        "defaultMode": "default"
    },
    "sandbox": {
        "enabled": true,
        "autoAllowBashIfSandboxed": true,
        "network": {
            "allowedDomains": [
                "api.anthropic.com",
                "github.com",
                "api.github.com",
                "claude.ai",
                "platform.claude.com",
                "registry.npmjs.org"
            ]
        },
        "filesystem": {
            "denyRead": [
                "~/.ssh",
                "~/.aws",
                "~/.azure",
                "~/.gnupg"
            ]
        }
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write|Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "jq -r '[.tool_name, (.tool_input.file_path // .tool_input.command // \"n/a\")] | @tsv' >> ~/.claude/audit.log 2>/dev/null || true",
                        "statusMessage": "Logging activity..."
                    }
                ]
            }
        ]
    }
}
